# URL de conexão com o banco de dados PostgreSQL
# Exemplo: postgresql://user:password@host:port/database
DATABASE_URL="postgresql://postgres:docker@localhost:5432/bjjrats"

# Segredo para assinar os tokens JWT (JSON Web Tokens)
# Pode ser qualquer string segura e longa
JWT_SECRET="SUPER_SECRET_JWT_KEY_CHANGE_ME"

# URL base da API para o cliente Vite
# Em desenvolvimento, geralmente aponta para o servidor local
VITE_API_URL="http://localhost:3000"

# Diretório para upload de arquivos (usado pelo Multer)
# O caminho deve ser relativo à raiz do projeto
UPLOADS_DIR="uploads"

# Origem permitida para requisições CORS
# Em desenvolvimento, geralmente é a URL do cliente Vite
CORS_ORIGIN="http://localhost:5173"

# Asaas Payment Gateway
# Chave de API do Asaas (sandbox ou produção)
ASAAS_API_KEY=""
# Defina como "true" para usar o ambiente sandbox do Asaas
ASAAS_SANDBOX="true"

# Token configurado no webhook do Asaas; usado para validar o header asaas-access-token
ASAAS_WEBHOOK_TOKEN=""

# Evolution API (WhatsApp)
# URL da sua instância Evolution API (ex: https://evolution.seuservidor.com)
EVOLUTION_API_URL=""
# API Key configurada na Evolution API
EVOLUTION_API_KEY=""
