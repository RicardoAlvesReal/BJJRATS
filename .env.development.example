# Ambiente local/desenvolvimento.
# Use este ambiente para manutencao, testes e novas funcionalidades.

APP_ENV="development"
NODE_ENV="development"

# Banco de desenvolvimento. Nunca use a URL de producao aqui.
# Se usar Fly remoto localmente, rode antes:
# fly proxy 15432:5432 -a bjjrats-db-dev
DATABASE_URL="postgresql://postgres:<senha-dev>@localhost:15432/postgres"

JWT_SECRET="CHANGE_ME_DEV"
VITE_API_URL="http://localhost:3001"
CORS_ORIGIN="http://localhost:5173"
PUBLIC_API_URL="http://localhost:3001"
UPLOADS_DIR="uploads"

ASAAS_API_KEY=""
ASAAS_SANDBOX="true"
ASAAS_WEBHOOK_TOKEN=""
PAYMENT_INTEGRATION_SECRET="CHANGE_ME_DEV"

EVOLUTION_API_URL=""
EVOLUTION_API_KEY=""

# E-mails enviados para o superadmin.
# Em dev, se nenhum provedor for configurado, a API usa log mode.
EMAIL_AUTOMATION_ENABLED="true"
EMAIL_AUTOMATION_PROVIDER="log"
EMAIL_AUTOMATION_DISABLED="false"
EMAIL_FROM="no-reply@thebjjrats.com"
RESEND_API_KEY=""
COMPANY_EMAIL_WEBHOOK_URL=""
COMPANY_EMAIL_WEBHOOK_KEY=""
SUPERADMIN_EMAIL_TO="admin@bjjrats.dev"
SUPERADMIN_EMAIL_PROVIDER="log"
SUPERADMIN_EMAIL_API_URL=""
SUPERADMIN_EMAIL_API_KEY=""

# Em dev, mantenha automacoes automaticas desligadas por padrao.
FINANCIAL_AUTOMATION_DISABLED="true"
FINANCIAL_AUTOMATION_INTERVAL_MS="21600000"
FINANCIAL_AUTOMATION_STARTUP_DELAY_MS="60000"
