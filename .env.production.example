# Ambiente de producao.
# No Fly.io, configure estes valores com `fly secrets set --app bjjrats`.

APP_ENV="production"
NODE_ENV="production"

# O Fly preenche este secret quando voce roda:
# fly postgres attach bjjrats-db-prod --app bjjrats
DATABASE_URL="postgresql://..."

JWT_SECRET="CHANGE_ME_PROD"
VITE_API_URL="https://seu-dominio.com"
CORS_ORIGIN="https://seu-dominio.com"
PUBLIC_API_URL="https://seu-dominio.com"
UPLOADS_DIR="/app/uploads"

ASAAS_API_KEY=""
ASAAS_SANDBOX="false"
ASAAS_WEBHOOK_TOKEN=""
PAYMENT_INTEGRATION_SECRET="CHANGE_ME_PROD"

EVOLUTION_API_URL=""
EVOLUTION_API_KEY=""

# E-mails enviados para o superadmin.
# Use Resend ou um webhook proprio. Se SUPERADMIN_EMAIL_TO ficar vazio,
# o backend usa os usuarios com role=superadmin como destinatarios.
EMAIL_AUTOMATION_ENABLED="true"
EMAIL_AUTOMATION_PROVIDER="resend"
EMAIL_AUTOMATION_DISABLED="false"
EMAIL_FROM="no-reply@thebjjrats.com"
RESEND_API_KEY=""
COMPANY_EMAIL_WEBHOOK_URL=""
COMPANY_EMAIL_WEBHOOK_KEY=""
SUPERADMIN_EMAIL_TO="contato@thebjjrats.com"
SUPERADMIN_EMAIL_PROVIDER="resend"
SUPERADMIN_EMAIL_API_URL=""
SUPERADMIN_EMAIL_API_KEY=""

FINANCIAL_AUTOMATION_DISABLED="false"
FINANCIAL_AUTOMATION_INTERVAL_MS="21600000"
FINANCIAL_AUTOMATION_STARTUP_DELAY_MS="60000"
