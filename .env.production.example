# Ambiente de producao.
# No Fly.io, configure estes valores com `fly secrets set --app bjjrats`.

APP_ENV="production"
NODE_ENV="production"

# O Fly preenche este secret quando voce roda:
# fly postgres attach bjjrats-db-prod --app bjjrats
DATABASE_URL="postgresql://..."

JWT_SECRET="CHANGE_ME_PROD"
VITE_API_URL="https://seu-dominio.com"
CORS_ORIGIN="https://seu-dominio.com"
PUBLIC_API_URL="https://seu-dominio.com"
UPLOADS_DIR="/app/uploads"

ASAAS_API_KEY=""
ASAAS_SANDBOX="false"
ASAAS_WEBHOOK_TOKEN=""
PAYMENT_INTEGRATION_SECRET="CHANGE_ME_PROD"

EVOLUTION_API_URL=""
EVOLUTION_API_KEY=""

FINANCIAL_AUTOMATION_DISABLED="false"
FINANCIAL_AUTOMATION_INTERVAL_MS="21600000"
FINANCIAL_AUTOMATION_STARTUP_DELAY_MS="60000"
